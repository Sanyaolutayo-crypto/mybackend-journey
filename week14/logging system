//Wintone Application logging
const winstone =
require("winstone");

const logger = 
winstone.createlogger({
    lelel: "info",
    //defailt level
    format:
    winstone.format.combine(
        winstone.format.timestamp(),
        winstone.format.json()
    ),
    transports: [
        // logs everything info and below to file
        new
        winstone.transports.File({ filename: "logs/app.log"}),

        //error logs only
        new
        winstone.transports.File({ filename: "logs/error.log", level: "error"}),
    ],

});

//if not in production-> also log to console
if (process.env.NODE_ENV !=="PRODUCTION"){
    OLGGER.ADD(
        new
        winstone.transports.Console({
            format:
            winstone.format.simple(),
        });
    );
    module.exports=logger;
}


